FROM node:26-alpine AS base
RUN apk add --no-cache libc6-compat curl tini
RUN addgroup --system --gid 1001 preflight && \
    adduser --system --uid 1001 preflight
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /runtime

FROM base AS deps
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json turbo.json .npmrc ./
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile --prod

FROM base
COPY --from=deps --chown=preflight:preflight /runtime/node_modules ./node_modules
COPY --from=deps --chown=preflight:preflight /runtime/package.json ./
COPY packages/core/runtime/dist ./dist
COPY packages/core/runtime/package.json ./package.json

ENV NODE_ENV=production
ENV PORT=3001
EXPOSE 3001

USER preflight

HEALTHCHECK --interval=15s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:$PORT/health || exit 1

STOPSIGNAL SIGTERM

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "dist/index.js"]
