{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@agent-preflight/*": ["./packages/*/src"]
    }
  },
  "include": [],
  "references": [
    { "path": "./packages/types" },
    { "path": "./packages/utils" },
    { "path": "./packages/config" },
    { "path": "./packages/protocol" },
    { "path": "./packages/security" },
    { "path": "./packages/memory" },
    { "path": "./packages/providers" },
    { "path": "./packages/evaluation" },
    { "path": "./packages/observability" },
    { "path": "./packages/analytics" },
    { "path": "./packages/cli" },
    { "path": "./packages/core/runtime" },
    { "path": "./packages/core/registry" },
    { "path": "./packages/core/orchestrator" }
  ]
}
